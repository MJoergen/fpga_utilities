[tasks]
cover
bmc

[options]
cover: mode cover
cover: depth 10
cover: append 3
bmc: mode bmc
bmc: depth 10

[engines]
smtbmc

[script]
ghdl --std=08 -gG_TIMEOUT_MAX=100 -gG_ADDR_BITS=4 -gG_DATA_BITS=16 axil_to_wbus.vhd axil_to_wbus.psl -e axil_to_wbus
prep -top axil_to_wbus

[files]
axil_to_wbus.psl
../src/converters/axil_to_wbus.vhd

