[tasks]
cover
bmc

[options]
cover: mode cover
cover: depth 13
cover: append 3
bmc: mode bmc
bmc: depth 13

[engines]
smtbmc

[script]
ghdl --std=08 -gG_ADDR_BITS=3 -gG_DATA_BYTES=2 axip_dropper.vhd axip_pkg.vhd axis_fifo.vhd axip_dropper.psl -e axip_dropper
prep -top axip_dropper

[files]
axip_dropper.psl
../src/axip/axip_dropper.vhd
../src/axip/axip_pkg.vhd
../src/axis/axis_fifo.vhd

