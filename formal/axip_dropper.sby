[tasks]
cover
bmc

[options]
cover: mode cover
cover: depth 10
cover: append 3
bmc: mode bmc
bmc: depth 10

[engines]
smtbmc

[script]
ghdl --std=08 -gG_ADDR_BITS=2 -gG_DATA_BYTES=4 axip_dropper.vhd axis_fifo.vhd axip_dropper.psl -e axip_dropper
prep -top axip_dropper

[files]
axip_dropper.psl
../src/axip/axip_dropper.vhd
../src/axis/axis_fifo.vhd

