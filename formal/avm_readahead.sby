[tasks]
bmc
cover

[options]
bmc: mode bmc
bmc: depth 8
cover: mode cover
cover: depth 9

[engines]
smtbmc

[script]
ghdl --std=08 -gG_BURST_WIDTH=4 -gG_CACHE_SIZE=4 -gG_ADDRESS_SIZE=4 -gG_DATA_SIZE=16 avm_readahead.vhd avm_readahead.psl -e avm_readahead
prep -top avm_readahead

[files]
avm_readahead.psl
../src/avm/avm_readahead.vhd

