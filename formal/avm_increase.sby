[tasks]
bmc

[options]
bmc: mode bmc
bmc: depth 9

[engines]
smtbmc

[script]
ghdl --std=08 -gG_BURST_BITS=4 -gG_SLAVE_DATA_BITS=8 -gG_MASTER_DATA_BITS=16 -gG_SLAVE_ADDR_BITS=10 -gG_MASTER_ADDR_BITS=9 avm_increase.vhd avm_increase.psl axis_fifo.vhd -e avm_increase
prep -top avm_increase

[files]
avm_increase.psl
../src/avm/avm_increase.vhd
../src/axis/axis_fifo.vhd

